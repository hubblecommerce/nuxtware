{
    // Type-check the tests against the REAL Nuxt types (generated by
    // `nuxt prepare`), the same environment `nuxt typecheck` uses — not the
    // Vitest runtime stubs. The `#imports`/`#shopware`/`#app` stubs in `stubs/`
    // are runtime-only aliases (see vitest.config.ts); using them here produced
    // false type errors that the CLI gate never saw. Inherits include + paths
    // (incl. `#nuxtware`) from the generated config.
    "extends": "../.playground/.nuxt/tsconfig.json"
}
